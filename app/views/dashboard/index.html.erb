<%# app/views/dashboard/index.html.erb %>
<div class="h-screen overflow-hidden flex flex-col p-4 lg:p-6 gap-4">

  <%# ページタイトル %>
  <div class="shrink-0 flex items-center justify-between">
    <div>
      <h1 class="text-lg font-black text-[#111718] dark:text-[#e6edf3]">ダッシュボード</h1>
      <p class="text-xs text-[#618689] dark:text-[#7d8590]">固定費の概要を確認できます</p>
    </div>
  </div>

  <%# バナー類 %>
  <div class="shrink-0 flex flex-col gap-2">
    <% unless @calc.income_set? %>
      <div class="relative overflow-hidden rounded-xl border border-[#13daec]/30 dark:border-[#b5f714]/20 bg-[#13daec]/5 dark:bg-[#b5f714]/5 px-4 py-2.5 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#13daec] dark:text-[#b5f714] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">月収が未設定です。月収を登録すると収入利用率を確認できます</p>
        </div>
        <button type="button"
                onclick="document.getElementById('income-modal').classList.remove('hidden')"
                class="shrink-0 h-7 px-3 rounded-lg bg-[#13daec] dark:bg-[#b5f714] hover:opacity-90 text-[#111718] text-xs font-bold transition-all">
          設定する
        </button>
      </div>
    <% end %>
    <% if @calc.income_set? && @calc.over_budget? %>
      <div class="flex items-center gap-3 rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <p class="text-xs font-bold text-red-700 dark:text-red-400">固定費が収入の<span class="font-black"><%= @calc.usage_rate %>%</span>を占めています。収入の50%を超えています。固定費の見直しを検討してください。</p>
      </div>
    <% end %>
  </div>

  <%# ヒーローカード 2枚 %>
  <div class="shrink-0 grid gap-3 lg:grid-cols-2">
    <div class="relative overflow-hidden rounded-xl bg-white dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] px-5 py-4 shadow-sm">
      <div class="absolute inset-0 pointer-events-none"
           style="background: radial-gradient(ellipse at 100% 0%, rgba(19,218,236,0.07) 0%, transparent 60%);"></div>
      <div class="relative z-10">
        <p class="text-xs font-bold tracking-widest uppercase text-[#13daec] mb-1">今月使えるお金</p>
        <% if @calc.income_set? %>
          <p class="text-4xl font-black <%= @calc.available_amount >= 0 ? 'text-[#111718] dark:text-[#e6edf3]' : 'text-red-500' %>">
            ¥<%= number_with_delimiter(@calc.available_amount) %>
          </p>
          <p class="text-xs text-[#618689] dark:text-[#7d8590] mt-1">
            月収 ¥<%= number_with_delimiter(current_user.monthly_income) %> − 固定費 ¥<%= number_with_delimiter(@calc.total_fixed_cost) %>
          </p>
        <% else %>
          <p class="text-3xl font-black text-gray-300 dark:text-[#30363d]">---</p>
          <p class="text-xs text-[#618689] dark:text-[#7d8590] mt-1">月収を設定すると表示されます</p>
        <% end %>
      </div>
    </div>
    <div class="relative overflow-hidden rounded-xl bg-white dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] px-5 py-4 shadow-sm">
      <div class="absolute inset-0 pointer-events-none"
           style="background: radial-gradient(ellipse at 0% 100%, rgba(19,218,236,0.05) 0%, transparent 60%);"></div>
      <div class="relative z-10 flex items-center justify-between gap-6">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase text-[#618689] dark:text-[#7d8590] mb-1">固定費合計</p>
          <p class="text-4xl font-black text-[#111718] dark:text-[#e6edf3]">¥<%= number_with_delimiter(@calc.total_fixed_cost) %></p>
          <p class="text-xs text-[#618689] dark:text-[#7d8590] mt-1"><%= current_user.fixed_expenses.where(is_active: true).count %>件の固定費</p>
        </div>
        <% if @calc.income_set? %>
          <div class="flex-1 max-w-40">
            <div class="flex items-center justify-between mb-1">
              <p class="text-xs text-[#618689] dark:text-[#7d8590]">収入利用率</p>
              <p class="text-xs font-black <%= @calc.usage_rate > 50 ? 'text-yellow-500' : 'text-[#13daec]' %>"><%= @calc.usage_rate %>%</p>
            </div>
            <div class="w-full bg-gray-100 dark:bg-[#30363d] rounded-full h-1.5">
              <div class="h-1.5 rounded-full <%= @calc.usage_rate > 50 ? 'bg-yellow-400' : 'bg-[#13daec]' %>"
                   style="width: <%= [@calc.usage_rate, 100].min %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# 3カラム %>
  <%# flex-1 min-h-0 で残り高さを確保、各カードも min-h-0 でオーバーフロー制御 %>
  <div class="flex-1 min-h-0 grid gap-3 lg:grid-cols-3">

    <%# 収入利用率ドーナツ %>
    
    <div class="bg-white dark:bg-[#1c2128] rounded-xl border border-gray-200 dark:border-[#30363d] p-4 shadow-sm flex flex-col gap-2 min-h-0 overflow-y-auto scrollbar-thin">
      <div class="shrink-0">
        <p class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">収入利用率</p>
        <p class="text-xs text-[#618689] dark:text-[#7d8590]">固定費 ÷ 月収</p>
      </div>
      <% if @calc.income_set? %>
        <% is_over = @calc.usage_rate > 50; remaining = @calc.available_amount %>
        <div class="shrink-0 relative flex items-center justify-center py-0.5">
          <canvas id="donut-chart"
                  width="80" height="80"
                  style="width:80px; height:80px;"
                  data-total="<%= @calc.total_fixed_cost %>"
                  data-remaining="<%= [remaining, 0].max %>"
                  data-rate="<%= @calc.usage_rate %>"></canvas>
          <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
            <span class="text-sm font-black <%= is_over ? 'text-red-500' : 'text-[#111718] dark:text-[#e6edf3]' %>"><%= @calc.usage_rate %>%</span>
            <span class="text-xs text-[#618689] dark:text-[#7d8590]">利用中</span>
          </div>
        </div>
        <%# ミニカード3枚：shrink-0で縦縮小時も消えないように %>
        <div class="shrink-0 grid grid-cols-2 gap-1.5">
          <div class="rounded-lg bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] p-2">
            <div class="flex items-center gap-1 mb-0.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shrink-0"></span>
              <p class="text-xs text-[#618689] dark:text-[#7d8590]">月収</p>
            </div>
            <p class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">¥<%= number_with_delimiter(current_user.monthly_income) %></p>
          </div>
          <div class="rounded-lg bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] p-2">
            <div class="flex items-center gap-1 mb-0.5">
              <span class="w-1.5 h-1.5 rounded-full shrink-0 <%= is_over ? 'bg-red-500' : 'bg-[#C7F284]' %>"></span>
              <p class="text-xs text-[#618689] dark:text-[#7d8590]">固定費</p>
            </div>
            <p class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">¥<%= number_with_delimiter(@calc.total_fixed_cost) %></p>
          </div>
          <div class="col-span-2 rounded-lg bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] p-2">
            <div class="flex items-center gap-1 mb-0.5">
              <span class="w-1.5 h-1.5 rounded-full shrink-0 <%= remaining >= 0 ? 'bg-[#13daec]' : 'bg-red-500' %>"></span>
              <p class="text-xs text-[#618689] dark:text-[#7d8590]">残り</p>
            </div>
            <p class="text-xs font-bold <%= remaining >= 0 ? 'text-[#111718] dark:text-[#e6edf3]' : 'text-red-500' %>">¥<%= number_with_delimiter(remaining) %></p>
          </div>
        </div>
      <% else %>
        <div class="flex-1 flex flex-col items-center justify-center gap-2">
          <div class="relative flex items-center justify-center w-20 h-20">
            <svg class="w-full h-full" viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="48" fill="none" stroke="#484f58" stroke-width="12"/>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-sm font-black text-gray-300 dark:text-[#484f58]">--%</span>
            </div>
          </div>
          <p class="text-xs text-[#618689] dark:text-[#7d8590]">月収設定後に表示</p>
        </div>
      <% end %>
    </div>

    <%# 直近の支払い %>
    <div class="bg-white dark:bg-[#1c2128] rounded-xl border border-gray-200 dark:border-[#30363d] shadow-sm flex flex-col min-h-0">
      <div class="px-3 py-2.5 border-b border-gray-100 dark:border-[#30363d] shrink-0">
        <p class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">直近の支払い</p>
        <p class="text-xs text-[#618689] dark:text-[#7d8590]">7日以内</p>
      </div>
      <% if @upcoming_payments.any? %>
        <div class="overflow-y-auto scrollbar-thin flex-1 min-h-0 divide-y divide-gray-100/50 dark:divide-[#30363d]/50">
          <% @upcoming_payments.each do |item| %>
            <% fe = item[:expense]; days = item[:days_until] %>
            <%
              label = case days when 0 then "今日" when 1 then "明日" else "#{days}日後" end
              label_class = case days
                            when 0, 1 then "bg-red-100 dark:bg-red-500/10 text-red-600 dark:text-red-400"
                            when 2, 3 then "bg-yellow-100 dark:bg-yellow-500/10 text-yellow-600 dark:text-yellow-400"
                            else "bg-gray-100 dark:bg-[#161b22] text-[#618689] dark:text-[#7d8590]"
                            end
            %>
            <div class="flex items-center justify-between px-3 py-2 hover:bg-gray-50 dark:hover:bg-[#161b22] transition-colors">
              <div class="flex items-center gap-2">
                <div class="w-6 h-6 rounded-md flex items-center justify-center shrink-0"
                    style="background-color: <%= fe.category.color %>25;">
                  <div class="w-1.5 h-1.5 rounded-full" style="background-color: <%= fe.category.color %>;"></div>
                </div>
                <div>
                  <p class="text-xs font-medium text-[#111718] dark:text-[#e6edf3]"><%= fe.name %></p>
                  <p class="text-xs text-[#618689] dark:text-[#7d8590]">毎月<%= fe.payment_day %>日</p>
                </div>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-xs font-bold px-1.5 py-0.5 rounded-md <%= label_class %>"><%= label %></span>
                <p class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">−¥<%= number_with_delimiter(fe.fixed_cost_amount) %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex-1 flex items-center justify-center">
          <p class="text-xs text-[#618689] dark:text-[#7d8590]">7日以内の支払いはありません</p>
        </div>
      <% end %>
    </div>

    <%# カテゴリ別内訳 %>
    <div class="bg-white dark:bg-[#1c2128] rounded-xl border border-gray-200 dark:border-[#30363d] shadow-sm flex flex-col min-h-0">
      <div class="px-3 py-2.5 border-b-2 border-gray-200 dark:border-[#484f58] shrink-0">
        <p class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">カテゴリ別内訳</p>
        <p class="text-xs text-[#618689] dark:text-[#7d8590]">固定費合計に占める割合</p>
      </div>
      <% if @category_breakdown.any? %>
        <div class="overflow-y-auto scrollbar-thin flex-1 min-h-0 p-3 flex flex-col gap-2.5">
          <% @category_breakdown.each do |item| %>
            <div class="flex flex-col gap-1">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full shrink-0" style="background-color: <%= item[:category].color %>;"></span>
                  <span class="text-xs font-medium text-[#111718] dark:text-[#e6edf3]"><%= item[:category].name %></span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-xs text-[#618689] dark:text-[#7d8590]">¥<%= number_with_delimiter(item[:amount]) %></span>
                  <span class="text-xs font-bold text-[#111718] dark:text-[#e6edf3] w-8 text-right"><%= item[:rate] %>%</span>
                </div>
              </div>
              <div class="w-full bg-gray-100 dark:bg-[#161b22] rounded-full h-1">
                <div class="h-1 rounded-full transition-all duration-500"
                    style="width: <%= item[:rate] %>%; background-color: <%= item[:category].color %>;"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex-1 flex items-center justify-center">
          <p class="text-xs text-[#618689] dark:text-[#7d8590]">固定費が登録されていません</p>
        </div>
      <% end %>
    </div>

  </div>

  <%# 直近の引き落とし履歴 %>
  <%# テーブル部分のみをスクロール可能にする %>
  <div class="flex-1 min-h-0 bg-white dark:bg-[#1c2128] rounded-xl border border-gray-200 dark:border-[#30363d] shadow-sm flex flex-col">
    <div class="px-4 py-3 border-b border-gray-100 dark:border-[#30363d] flex items-center justify-between shrink-0">
      <div>
        <p class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">直近の引き落とし履歴</p>
        <p class="text-xs text-[#618689] dark:text-[#7d8590]">当月の支払日が過ぎた固定費</p>
      </div>
      <%= link_to "すべて見る →", fixed_expenses_path, class: "text-xs font-bold text-[#13daec] hover:underline" %>
    </div>
    <% if @paid_this_month.any? %>
      <%# テーブル部分のみをスクロール可能にする %>
      <div class="flex-1 min-h-0 overflow-y-auto scrollbar-thin">
        <table class="w-full">
          <thead class="sticky top-0 bg-white dark:bg-[#1c2128] z-10">
            <tr class="border-b border-gray-100 dark:border-[#30363d]">
              <th class="px-4 py-2 text-left text-xs font-bold text-[#618689] dark:text-[#7d8590] uppercase tracking-wider">名称</th>
              <th class="px-4 py-2 text-left text-xs font-bold text-[#618689] dark:text-[#7d8590] uppercase tracking-wider">カテゴリ</th>
              <th class="px-4 py-2 text-center text-xs font-bold text-[#618689] dark:text-[#7d8590] uppercase tracking-wider">引き落とし日</th>
              <th class="px-4 py-2 text-right text-xs font-bold text-[#618689] dark:text-[#7d8590] uppercase tracking-wider">金額</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-[#30363d]">
            <% @paid_this_month.each do |fe| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-[#161b22] transition-colors">
                <td class="px-4 py-2.5"><p class="text-xs font-medium text-[#111718] dark:text-[#e6edf3]"><%= fe.name %></p></td>
                <td class="px-4 py-2.5">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium text-white"
                        style="background-color: <%= fe.category.color %>;"><%= fe.category.name %></span>
                </td>
                <td class="px-4 py-2.5 text-center">
                  <span class="text-xs text-[#618689] dark:text-[#7d8590]"><%= Date.today.strftime("%Y年%-m月") %><%= fe.payment_day %>日</span>
                </td>
                <td class="px-4 py-2.5 text-right">
                  <span class="text-xs font-bold text-[#111718] dark:text-[#e6edf3]">−¥<%= number_with_delimiter(fe.fixed_cost_amount) %></span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <%# フッターは常時表示 %>
      <div class="px-4 py-2.5 border-t border-gray-100 dark:border-[#30363d] flex items-center justify-between bg-gray-50 dark:bg-[#161b22] shrink-0">
        <span class="text-xs text-[#618689] dark:text-[#7d8590]">全 <span class="font-bold text-[#111718] dark:text-[#e6edf3]"><%= @paid_this_month.count %></span> 件</span>
        <div>
          <span class="text-xs text-[#618689] dark:text-[#7d8590] mr-2">当月引き落とし済み合計</span>
          <span class="text-sm font-black text-[#111718] dark:text-[#e6edf3]">−¥<%= number_with_delimiter(@paid_this_month.sum(&:fixed_cost_amount)) %></span>
        </div>
      </div>
    <% else %>
      <div class="flex-1 flex items-center justify-center">
        <p class="text-xs text-[#618689] dark:text-[#7d8590]">当月の引き落とし済み固定費はありません</p>
      </div>
    <% end %>
  </div>

</div>

<%# 月収入力モーダル %>
<div id="income-modal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
     onclick="if(event.target === this) this.classList.add('hidden')">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative z-10 w-full max-w-md bg-white dark:bg-[#161b22] rounded-2xl border border-gray-200 dark:border-[#30363d] shadow-2xl p-6 flex flex-col gap-5">
    <div>
      <h3 class="text-lg font-bold text-[#111718] dark:text-[#e6edf3]">月収を設定する</h3>
      <p class="text-sm text-[#618689] dark:text-[#7d8590] mt-1">手取りの月収入を入力してください</p>
    </div>
    <%= form_with url: update_income_user_path(current_user), method: :patch, local: true do |f| %>
      <div class="flex flex-col gap-4">
        <div>
          <%= f.label :monthly_income, "月収（円）", class: "block text-sm font-medium text-[#111718] dark:text-[#7d8590] mb-1" %>
          <div class="relative">
            <input type="text" id="income-input" placeholder="例：300,000" autocomplete="off"
                   class="w-full h-11 px-4 pr-8 rounded-lg bg-gray-50 dark:bg-[#1c2128] border border-gray-200 dark:border-[#30363d] text-[#111718] dark:text-[#e6edf3] placeholder-gray-400 dark:placeholder-[#7d8590] focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 dark:focus:ring-[#b5f714]/30 focus:border-[#13daec] dark:focus:border-[#b5f714] transition-colors" />
            <input type="hidden" id="income-value" name="user[monthly_income]" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-[#618689] dark:text-[#7d8590]">円</span>
          </div>
          <p class="text-xs text-[#618689] dark:text-[#7d8590] mt-1">入力した月収はあなただけが確認できます</p>
        </div>
        <div class="flex gap-3">
          <button type="button" onclick="document.getElementById('income-modal').classList.add('hidden')"
                  class="flex-1 h-11 rounded-lg bg-gray-100 dark:bg-[#1c2128] text-[#111718] dark:text-[#e6edf3] font-bold text-sm hover:bg-gray-200 dark:hover:bg-[#30363d] transition-colors border border-transparent dark:border-[#30363d]">
            キャンセル
          </button>
          <%= f.submit "設定する", class: "flex-1 h-11 rounded-lg bg-[#13daec] dark:bg-[#b5f714] hover:opacity-90 text-[#111718] font-bold text-sm transition-all cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
