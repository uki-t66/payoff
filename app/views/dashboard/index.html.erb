<div class="p-6 lg:p-10 flex flex-col gap-6">

  <div>
    <h1 class="text-2xl font-black text-[#111718] dark:text-white">ダッシュボード</h1>
    <p class="text-sm text-[#618689] dark:text-slate-400 mt-1">固定費の概要を確認できます</p>
  </div>

  <%# 月収未設定バナー %>
  <% if current_user.monthly_income.nil? %>
    <div class="relative overflow-hidden rounded-2xl border border-[#13daec]/30 bg-[#13daec]/5 dark:bg-[#13daec]/10 p-5 flex items-center justify-between gap-4">
      <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(#13daec 1px, transparent 1px); background-size: 16px 16px;"></div>
      <div class="relative z-10 flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-[#13daec]/20 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#13daec]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-[#111718] dark:text-white">月収が未設定です</p>
          <p class="text-xs text-[#618689] dark:text-slate-400 mt-0.5">月収を登録すると固定費の収入利用率を確認できます</p>
        </div>
      </div>
      <button type="button"
              onclick="document.getElementById('income-modal').classList.remove('hidden')"
              class="relative z-10 shrink-0 h-9 px-4 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] text-sm font-bold transition-all">
        月収を設定する
      </button>
    </div>
  <% end %>

</div>

<%# 月収入力モーダル %>
<div id="income-modal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
     onclick="if(event.target === this) this.classList.add('hidden')">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="relative z-10 w-full max-w-md bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-2xl p-6 flex flex-col gap-5">

    <div>
      <h3 class="text-lg font-bold text-[#111718] dark:text-white">月収を設定する</h3>
      <p class="text-sm text-[#618689] dark:text-slate-400 mt-1">手取りの月収入を入力してください</p>
    </div>

    <%= form_with url: update_income_user_path(current_user), method: :patch, local: true do |f| %>
      <div class="flex flex-col gap-4">
        <div>
            <%= f.label :monthly_income, "月収（円）",
                class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
            <div class="relative">
                <%# 表示用（カンマあり） %>
                <input type="text"
                    id="income-input"
                    placeholder="例：300,000"
                    autocomplete="off"
                    class="w-full h-11 px-4 pr-8 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" />
                <%# 送信用（数値のみ） %>
                <input type="hidden"
                    id="income-value"
                    name="user[monthly_income]" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-[#618689] dark:text-slate-400">円</span>
            </div>
            <p class="text-xs text-[#618689] dark:text-slate-500 mt-1">入力した月収はあなただけが確認できます</p>
        </div>

        <div class="flex gap-3">
          <button type="button"
                  onclick="document.getElementById('income-modal').classList.add('hidden')"
                  class="flex-1 h-11 rounded-lg bg-gray-100 dark:bg-white/10 text-[#111718] dark:text-white font-bold text-sm hover:bg-gray-200 dark:hover:bg-white/20 transition-colors">
            キャンセル
          </button>
          <%= f.submit "設定する",
              class: "flex-1 h-11 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] font-bold text-sm transition-all cursor-pointer" %>
        </div>
      </div>
    <% end %>

  </div>
</div>