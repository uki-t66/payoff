<!DOCTYPE html>
<html lang="ja" class="dark">
  <head>
    <title><%= content_for(:title) || "Myapp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-[#090D10]">

    <% if logged_in? && controller_name != 'pages' %>
      <%= render "shared/header" %>
    <% end %>
    
    <% if notice %>
      <div class="fixed top-4 right-4 z-50 px-5 py-3 rounded-lg bg-[#13daec]/10 border border-[#13daec]/30 text-[#13daec] text-sm font-medium shadow-lg">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="fixed top-4 right-4 z-50 px-5 py-3 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400 text-sm font-medium shadow-lg">
        <%= alert %>
      </div>
    <% end %>
    <%= yield %>
  </body>
</html>
