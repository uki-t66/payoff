<div class="p-6 lg:p-10 max-w-2xl mx-auto flex flex-col gap-6">

  <div>
    <h1 class="text-2xl font-black text-[#111718] dark:text-white">アカウント設定</h1>
    <p class="text-sm text-[#618689] dark:text-slate-400 mt-1">アカウント情報の確認・変更ができます</p>
  </div>

  <%# ユーザー名変更カード %>
  <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-white/10">
      <h2 class="text-base font-bold text-[#111718] dark:text-white">ユーザー名</h2>
      <p class="text-sm text-[#618689] dark:text-slate-400 mt-0.5">表示名を変更できます</p>
    </div>
    <div class="p-6">
      <% if @user.errors[:name].any? %>
        <div class="mb-4 rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 p-4">
            <ul class="text-sm text-red-600 dark:text-red-400 space-y-1">
            <% @user.errors[:name].each do |message| %>
                <li>・ ユーザー名<%= message %></li>
            <% end %>
            </ul>
        </div>
    <% end %>

      <%= form_with model: @user, url: user_path(@user), method: :patch, local: true do |f| %>
        <div class="flex gap-3 items-end">
          <div class="flex-1">
            <%= f.label :name, "ユーザー名",
                class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
            <%= f.text_field :name,
                class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
          </div>
          <%= f.submit "変更する",
              class: "h-11 px-5 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] font-bold text-sm transition-all cursor-pointer shrink-0" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# 月収カード %>
  <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-white/10">
      <h2 class="text-base font-bold text-[#111718] dark:text-white">月収</h2>
      <p class="text-sm text-[#618689] dark:text-slate-400 mt-0.5">手取りの月収入を設定できます</p>
    </div>
    <div class="p-6">
      <% if @user.errors[:monthly_income].any? %>
        <div class="mb-4 rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 p-4">
          <ul class="text-sm text-red-600 dark:text-red-400 space-y-1">
            <% @user.errors[:monthly_income].each do |message| %>
              <li>・ 月収<%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with url: update_income_user_path(@user), method: :patch, local: true do |f| %>
        <div class="flex gap-3 items-end">
          <div class="flex-1">
            <%= f.label :monthly_income, "月収（円）",
                class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
            <div class="relative">
              <%# 表示用（カンマあり） %>
              <input type="text"
                    id="income-input-settings"
                    value="<%= number_with_delimiter(@user.monthly_income) if @user.monthly_income %>"
                    placeholder="例：300,000"
                    autocomplete="off"
                    class="w-full h-11 px-4 pr-8 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" />
              <%# 送信用（数値のみ） %>
              <input type="hidden"
                    id="income-value-settings"
                    name="user[monthly_income]"
                    value="<%= @user.monthly_income %>" />
              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-[#618689] dark:text-slate-400">円</span>
            </div>
          </div>
          <button type="submit"
                  class="h-11 px-5 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] font-bold text-sm transition-all shrink-0">
            <%= @user.monthly_income.nil? ? "設定する" : "変更する" %>
          </button>
        </div>
      <% end %>
    </div>
  </div>

  <%# メールアドレス変更カード %>
  <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100 dark:border-white/10">
    <h2 class="text-base font-bold text-[#111718] dark:text-white">メールアドレス</h2>
    <p class="text-sm text-[#618689] dark:text-slate-400 mt-0.5">ログインに使用するメールアドレスを変更できます</p>
  </div>
  <div class="p-6">
    <% if @user.errors[:email].any? %>
      <div class="mb-4 rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 p-4">
        <ul class="text-sm text-red-600 dark:text-red-400 space-y-1">
          <% @user.errors[:email].each do |message| %>
            <li>・ メールアドレス<%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: user_path(@user), method: :patch, local: true do |f| %>
      <div class="flex gap-3 items-end">
        <div class="flex-1">
          <%= f.label :email, "メールアドレス",
              class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
          <%= f.email_field :email,
              class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
        </div>
        <%= f.submit "変更する",
            class: "h-11 px-5 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] font-bold text-sm transition-all cursor-pointer shrink-0" %>
      </div>
    <% end %>
  </div>
  </div>

  <%# パスワード変更カード %>
  <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100 dark:border-white/10">
    <h2 class="text-base font-bold text-[#111718] dark:text-white">パスワード</h2>
    <p class="text-sm text-[#618689] dark:text-slate-400 mt-0.5">現在のパスワードを入力して変更できます</p>
  </div>
  <div class="p-6">
    <% if @user.errors[:current_password].any? || @user.errors[:password].any? || @user.errors[:password_confirmation].any? %>
      <div class="mb-4 rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 p-4">
        <ul class="text-sm text-red-600 dark:text-red-400 space-y-1">
          <% @user.errors[:current_password].each do |message| %>
            <li>・ 現在のパスワード<%= message %></li>
          <% end %>
          <% @user.errors[:password].each do |message| %>
            <li>・ 新しいパスワード<%= message %></li>
          <% end %>
          <% @user.errors[:password_confirmation].each do |message| %>
            <li>・ 確認用パスワード<%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: user_path(@user), method: :patch, local: true do |f| %>
      <div class="flex flex-col gap-4">
        <%# 現在のパスワード %>
        <div>
          <%= f.label :current_password, "現在のパスワード",
              class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
          <div class="relative">
            <%= f.password_field :current_password,
                value: params.dig(:user, :current_password),
                autocomplete: "current-password",
                id: "current_password_field",
                class: "w-full h-11 px-4 pr-11 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
            <button type="button"
                    onclick="togglePasswordVisibility('current_password_field', this)"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-slate-300 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
        </div>

        <%# 新しいパスワード %>
        <div>
          <%= f.label :password, "新しいパスワード",
              class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
          <div class="relative">
            <%= f.password_field :password,
                value: params.dig(:user, :password),
                autocomplete: "new-password",
                id: "new_password_field",
                class: "w-full h-11 px-4 pr-11 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
            <button type="button"
                    onclick="togglePasswordVisibility('new_password_field', this)"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-slate-300 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
        </div>

        <%# 確認用パスワード %>
        <div>
          <%= f.label :password_confirmation, "新しいパスワード（確認）",
              class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
          <div class="relative">
            <%= f.password_field :password_confirmation,
                value: params.dig(:user, :password_confirmation),
                autocomplete: "new-password",
                id: "password_confirmation_field",
                class: "w-full h-11 px-4 pr-11 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
            <button type="button"
                    onclick="togglePasswordVisibility('password_confirmation_field', this)"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-slate-300 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
        </div>
      <%# 送信ボタン %>
        <div class="flex justify-end">
          <%= f.submit "パスワードを変更する",
              class: "h-11 px-5 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] font-bold text-sm transition-all cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
  </div>

  <%# アカウント削除カード %>
  <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-red-200 dark:border-red-500/20 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-red-100 dark:border-red-500/20">
      <h2 class="text-base font-bold text-red-600 dark:text-red-400">アカウント削除</h2>
      <p class="text-sm text-[#618689] dark:text-slate-400 mt-0.5">一度削除すると元に戻せません</p>
    </div>
    <div class="p-6 flex justify-end">
      <button type="button"
              onclick="document.getElementById('delete-modal').classList.remove('hidden')"
              class="h-10 px-5 rounded-lg bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 font-bold text-sm border border-red-200 dark:border-red-500/20 hover:bg-red-100 dark:hover:bg-red-500/20 transition-colors">
        アカウントを削除する
      </button>
    </div>
  </div>

  <%# 削除確認モーダル %>
  <div id="delete-modal"
      class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
      onclick="if(event.target === this) this.classList.add('hidden')">

    <%# 背景オーバーレイ %>
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <%# モーダル本体 %>
    <div class="relative z-10 w-full max-w-md bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-2xl p-6 flex flex-col gap-5">

      <%# アイコン %>
      <div class="flex items-center justify-center w-12 h-12 rounded-full bg-red-100 dark:bg-red-500/10 mx-auto">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>

      <%# テキスト %>
      <div class="text-center">
        <h3 class="text-lg font-bold text-[#111718] dark:text-white mb-2">アカウントを削除しますか？</h3>
        <p class="text-sm text-[#618689] dark:text-slate-400">この操作は取り消せません。登録済みの固定費データもすべて削除されます。</p>
      </div>

      <%# ボタン %>
      <div class="flex gap-3">
        <button type="button"
                onclick="document.getElementById('delete-modal').classList.add('hidden')"
                class="flex-1 h-12 rounded-lg bg-gray-100 dark:bg-white/10 text-[#111718] dark:text-white font-bold text-sm hover:bg-gray-200 dark:hover:bg-white/20 transition-colors">
          キャンセル
        </button>
        <%= button_to "削除する", user_path(@user), method: :delete,
            class: "flex-1 h-12 px-8 rounded-lg bg-red-600 hover:bg-red-700 text-white font-bold text-base transition-colors cursor-pointer" %>
      </div>

    </div>
  </div>

</div>