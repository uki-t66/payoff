<%# app/views/users/new.html.erb %>
<div class="min-h-screen bg-[#f6f8f8] dark:bg-[#102022] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">

    <%# ロゴ %>
    <div class="text-center mb-8">
      <h1 class="text-2xl font-black text-[#111718] dark:text-white">FixedFlow</h1>
      <p class="text-sm text-[#618689] dark:text-slate-400 mt-1">アカウントを作成する</p>
    </div>

    <%# フォームカード %>
    <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm p-8">

      <%# エラー表示 %>
      <% if @user.errors.any? %>
        <div class="mb-6 rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 p-4">
          <p class="text-sm font-bold text-red-700 dark:text-red-400 mb-2">入力内容を確認してください</p>
          <ul class="text-sm text-red-600 dark:text-red-400 space-y-1">
            <% @user.errors.full_messages.each do |message| %>
              <li>・ <%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @user, local: true do |f| %>

        <%# ユーザー名 %>
        <div class="mb-4">
          <%= f.label :name, "ユーザー名",
              class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
          <%= f.text_field :name,
              class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors",
              placeholder: "田中 太郎" %>
        </div>

        <%# メールアドレス %>
        <div class="mb-4">
          <%= f.label :email, "メールアドレス",
              class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
          <%= f.email_field :email,
              class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors",
              placeholder: "example@email.com" %>
        </div>

        <%# パスワード %>
        <div class="mb-4">
          <%= f.label :password, "パスワード",
              class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
          <%= f.password_field :password,
              class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors",
              placeholder: "8文字以上" %>
        </div>

        <%# パスワード確認用 %>
        <div class="mb-6">
          <%= f.label :password_confirmation, "パスワード（確認用）",
              class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
          <%= f.password_field :password_confirmation,
              class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors",
              placeholder: "もう一度入力" %>
        </div>

        <%# 登録ボタン %>
        <%= f.submit "アカウントを作成する",
            class: "w-full h-11 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] font-bold text-base transition-all shadow-sm shadow-[#13daec]/20 cursor-pointer" %>

      <% end %>
    </div>

    <%# ログインへの導線 %>
    <p class="text-center text-sm text-[#618689] dark:text-slate-400 mt-6">
      すでにアカウントをお持ちの方は
      <%= link_to "ログイン", "#", class: "text-[#13daec] font-medium hover:underline" %>
    </p>

  </div>
</div>