<div class="p-6 lg:p-10 flex flex-col gap-6">

  <%# ヘッダー %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black text-[#111718] dark:text-white">固定費一覧</h1>
      <p class="text-sm text-[#618689] dark:text-slate-400 mt-1">登録済みの固定費を管理できます</p>
    </div>
    <%= link_to new_fixed_expense_path,
        class: "flex items-center gap-2 h-10 px-4 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] text-sm font-bold transition-all shadow-sm" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      固定費を追加
    <% end %>
  </div>

  <% if @fixed_expenses.empty? %>

    <%# 空状態 %>
    <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm p-16 flex flex-col items-center justify-center gap-4 text-center">
      <div class="w-16 h-16 rounded-full bg-[#13daec]/10 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[#13daec]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
      </div>
      <div>
        <p class="text-base font-bold text-[#111718] dark:text-white mb-1">固定費が登録されていません</p>
        <p class="text-sm text-[#618689] dark:text-slate-400">最初の固定費を登録してみましょう</p>
      </div>
      <%= link_to "固定費を登録する", new_fixed_expense_path,
          class: "mt-2 flex items-center gap-2 h-10 px-6 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] text-sm font-bold transition-all" %>
    </div>

  <% else %>

    <%# テーブル %>
    <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-100 dark:border-white/10">
            <th class="px-6 py-3 text-left text-xs font-bold text-[#618689] dark:text-slate-400 uppercase tracking-wider">名称</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-[#618689] dark:text-slate-400 uppercase tracking-wider">カテゴリ</th>
            <th class="px-6 py-3 text-right text-xs font-bold text-[#618689] dark:text-slate-400 uppercase tracking-wider">月額</th>
            <th class="px-6 py-3 text-center text-xs font-bold text-[#618689] dark:text-slate-400 uppercase tracking-wider">支払日</th>
            <th class="px-6 py-3 text-center text-xs font-bold text-[#618689] dark:text-slate-400 uppercase tracking-wider">ステータス</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-white/5">
          <% @fixed_expenses.each do |fe| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">

              <%# 名称 %>
              <td class="px-6 py-4">
                <span class="text-sm font-medium text-[#111718] dark:text-white"><%= fe.name %></span>
              </td>

              <%# カテゴリバッジ %>
              <td class="px-6 py-4">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium text-white"
                      style="background-color: <%= fe.category.color %>;">
                  <%= fe.category.name %>
                </span>
              </td>

              <%# 月額 %>
              <td class="px-6 py-4 text-right">
                <span class="text-sm font-bold text-[#111718] dark:text-white">¥<%= number_with_delimiter(fe.fixed_cost_amount) %></span>
              </td>

              <%# 支払日 %>
              <td class="px-6 py-4 text-center">
                <span class="text-sm text-[#618689] dark:text-slate-400">毎月<%= fe.payment_day %>日</span>
              </td>

              <%# ステータス %>
              <td class="px-6 py-4 text-center">
                <% if fe.is_active %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-100 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                    有効
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-white/5 text-gray-500 dark:text-slate-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
                    無効
                  </span>
                <% end %>
              </td>

              <%# アクション %>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to edit_fixed_expense_path(fe),
                      class: "flex items-center justify-center w-8 h-8 rounded-lg bg-gray-100 dark:bg-white/5 hover:bg-gray-200 dark:hover:bg-white/10 text-[#618689] dark:text-slate-400 transition-colors" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  <% end %>
                </div>
              </td>

            </tr>
          <% end %>
        </tbody>
      </table>

      <%# フッター：件数と合計 %>
      <div class="px-6 py-4 border-t border-gray-100 dark:border-white/10 flex items-center justify-between bg-gray-50 dark:bg-white/5">
        <span class="text-sm text-[#618689] dark:text-slate-400">
          全 <span class="font-bold text-[#111718] dark:text-white"><%= @fixed_expenses.count %></span> 件
        </span>
        <div class="text-right">
          <span class="text-xs text-[#618689] dark:text-slate-400 mr-2">今月の合計</span>
          <span class="text-lg font-black text-[#111718] dark:text-[#13daec]">¥<%= number_with_delimiter(@total_amount) %></span>
        </div>
      </div>

    </div>

  <% end %>

</div>