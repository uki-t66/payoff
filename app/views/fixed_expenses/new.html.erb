<div class="p-6 lg:p-10 max-w-2xl mx-auto flex flex-col gap-6">

  <div>
    <h1 class="text-2xl font-black text-[#111718] dark:text-white">固定費を登録</h1>
    <p class="text-sm text-[#618689] dark:text-slate-400 mt-1">毎月発生する固定費を登録してください</p>
  </div>

  <div class="bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm overflow-hidden">
    <div class="p-6">

      <%# エラー表示 %>
      <% if @fixed_expense.errors.any? %>
        <div class="mb-6 rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 p-4">
          <ul class="text-sm text-red-600 dark:text-red-400 space-y-1">
            <% @fixed_expense.errors.full_messages.each do |message| %>
              <li>・ <%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @fixed_expense, url: fixed_expenses_path, local: true do |f| %>
        <div class="flex flex-col gap-5">

          <%# カテゴリ %>
          <div>
            <%= f.label :category_id, "カテゴリ",
                class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
            <%= f.select :category_id,
                @categories.map { |c| [c.name, c.id] },
                { prompt: "カテゴリを選択" },
                class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
          </div>

          <%# 名称 %>
          <div>
            <%= f.label :name, "名称",
                class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
            <%= f.text_field :name,
                placeholder: "例：Netflix、電気代、家賃",
                class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
          </div>

          <%# 月額 %>
          <div>
            <%= f.label :fixed_cost_amount, "月額（円）",
                class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
            <div class="relative">
              <%= f.number_field :fixed_cost_amount,
                  placeholder: "例：1500",
                  min: 1,
                  class: "w-full h-11 px-4 pr-8 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-[#618689] dark:text-slate-400">円</span>
            </div>
          </div>

          <%# 支払日 %>
          <div>
            <%= f.label :payment_day, "支払日",
                class: "block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1" %>
            <%= f.select :payment_day,
                (1..31).map { |d| ["毎月#{d}日", d] },
                { prompt: "支払日を選択" },
                class: "w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-[#111718] dark:text-white focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors" %>
          </div>

          <%# ボタン %>
          <div class="flex gap-3 pt-2">
            <%= link_to "キャンセル", fixed_expenses_path,
                class: "flex-1 h-11 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-white/10 text-[#111718] dark:text-white font-bold text-sm hover:bg-gray-200 dark:hover:bg-white/20 transition-colors" %>
            <%= f.submit "登録する",
                class: "flex-1 h-11 rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] font-bold text-sm transition-all cursor-pointer" %>
          </div>

        </div>
      <% end %>
    </div>
  </div>

</div>