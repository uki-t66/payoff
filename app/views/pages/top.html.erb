<%# app/views/pages/top.html.erb %>
<div class="relative flex min-h-screen w-full flex-col bg-[#f6f8f8] dark:bg-[#102022] text-[#111718] dark:text-slate-100 transition-colors duration-300">

  <%# 背景グリッドパターン %>
  <div class="absolute inset-0 z-0 pointer-events-none opacity-40 dark:opacity-3"
       style="background-image: linear-gradient(to right, #e5e7eb 1px, transparent 1px), linear-gradient(to bottom, #e5e7eb 1px, transparent 1px); background-size: 40px 40px;"></div>

  <%# ヘッダー %>
  <header class="sticky top-0 z-50 flex items-center justify-between border-b border-gray-200 dark:border-white/10 bg-white/80 dark:bg-[#102022]/80 backdrop-blur-md px-6 py-4 lg:px-40">
    <div class="flex items-center gap-3">
      <div class="flex items-center justify-center w-8 h-8 rounded bg-[#13daec]/20 text-[#13daec]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h2 class="text-[#111718] dark:text-white text-xl font-bold tracking-tight">FixedFlow</h2>
    </div>

    <div class="hidden lg:flex flex-1 justify-end gap-8 items-center">

     <%# ヘッダー昨日、料金項目 %>
      <%#<nav class="flex items-center gap-8">
        <a class="text-[#111718]/80 dark:text-slate-300 hover:text-[#13daec] text-sm font-medium transition-colors" href="#">機能</a>
        <a class="text-[#111718]/80 dark:text-slate-300 hover:text-[#13daec] text-sm font-medium transition-colors" href="#">料金</a>
      </nav>
      %>
      
      <div class="flex gap-3 items-center">
        <%# テーマ切り替えボタン %>
        <button id="theme-toggle" class="flex items-center justify-center w-10 h-10 rounded-lg bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/20 text-[#111718] dark:text-slate-300 transition-colors" aria-label="テーマ切り替え">
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>
        <%= link_to "ログイン", "#",
            class: "flex h-10 px-5 items-center justify-center rounded-lg bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/20 text-[#111718] dark:text-white text-sm font-bold transition-colors" %>
        <%= link_to "無料で始める", "#",
            class: "flex h-10 px-5 items-center justify-center rounded-lg bg-[#13daec] hover:bg-[#13daec]/90 text-[#111718] text-sm font-bold shadow-sm shadow-[#13daec]/20 transition-all" %>
      </div>
    </div>

    <%# モバイルメニュー %>
    <div class="lg:hidden flex items-center gap-2">
      <button id="theme-toggle-mobile" class="flex items-center justify-center w-9 h-9 rounded-lg bg-gray-100 dark:bg-white/10 text-[#111718] dark:text-slate-300 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
      </button>
    </div>
  </header>

  <main class="relative z-10 flex-1 flex flex-col items-center w-full">
    <div class="max-w-7xl w-full px-4 lg:px-8 py-12 lg:py-20 flex flex-col gap-20">

      <%# ヒーローセクション %>
      <section class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="flex flex-col gap-6 order-2 lg:order-1">
          <div class="inline-flex w-fit items-center gap-2 rounded-full border border-[#13daec]/30 bg-[#13daec]/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-[#111718] dark:text-white">
            <span class="w-2 h-2 rounded-full bg-[#13daec]"></span>
            固定費管理ダッシュボード
          </div>
          <h1 class="text-4xl lg:text-6xl font-black tracking-tight text-[#111718] dark:text-white leading-[1.1]">
            今月、<span class="text-transparent bg-clip-text bg-linear-to-r from-[#13daec] to-teal-500">いくら使える？</span>を把握する
          </h1>
          <p class="text-lg text-[#618689] dark:text-slate-400 max-w-lg leading-relaxed">
            家賃・保険・サブスク・ローン。毎月確実に消えていく固定費を一元管理。「気づいたらお金がない」を、もう繰り返さない。
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <%= link_to "ダッシュボードを試す", "#",
                class: "flex h-12 px-6 items-center justify-center rounded-lg bg-[#111718] dark:bg-white hover:bg-black dark:hover:bg-slate-100 text-white dark:text-[#111718] text-base font-bold transition-all shadow-lg" %>
            <%= link_to "詳しく見る", "#",
                class: "flex h-12 px-6 items-center justify-center rounded-lg bg-white dark:bg-white/10 border border-gray-200 dark:border-white/20 hover:border-[#13daec]/50 text-[#111718] dark:text-white text-base font-medium transition-all" %>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-8 mt-8 border-t border-gray-200 dark:border-white/10">
            <div class="flex flex-col gap-2">
              <div class="p-2 w-fit rounded bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
              </div>
              <h3 class="font-bold text-[#111718] dark:text-white">即時計算</h3>
              <p class="text-sm text-[#618689] dark:text-slate-400">固定費を登録するだけで今月使えるお金を自動計算。</p>
            </div>
            <div class="flex flex-col gap-2">
              <div class="p-2 w-fit rounded bg-purple-50 dark:bg-purple-500/10 text-purple-600 dark:text-purple-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
              <h3 class="font-bold text-[#111718] dark:text-white">カレンダー管理</h3>
              <p class="text-sm text-[#618689] dark:text-slate-400">支払日をカレンダーで可視化。引き落とし忘れをゼロに。</p>
            </div>
            <div class="flex flex-col gap-2">
              <div class="p-2 w-fit rounded bg-green-50 dark:bg-green-500/10 text-green-600 dark:text-green-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <h3 class="font-bold text-[#111718] dark:text-white">支出上限の警告</h3>
              <p class="text-sm text-[#618689] dark:text-slate-400">固定費が収入の50%を超えると自動で警告を表示。</p>
            </div>
          </div>
        </div>

        <%# ダッシュボードモックアップ %>
        <div class="relative order-1 lg:order-2">
          <div class="relative z-10 rounded-2xl bg-white dark:bg-[#1a2e30] shadow-2xl border border-gray-100 dark:border-white/10 overflow-hidden">
            <%# ウィンドウバー %>
            <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-100 dark:border-white/10">
              <div class="w-3 h-3 rounded-full bg-red-400/70"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400/70"></div>
              <div class="w-3 h-3 rounded-full bg-[#13daec]/70"></div>
              <span class="ml-2 text-xs text-gray-400 dark:text-slate-500">ダッシュボード</span>
            </div>
            <div class="p-6">
              <%# 警告バナー %>
              <div class="flex items-center gap-2 rounded-lg bg-yellow-50 dark:bg-yellow-500/10 border border-yellow-200 dark:border-yellow-500/20 px-3 py-2 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                <span class="text-xs text-yellow-700 dark:text-yellow-400 font-medium">固定費が収入の50%を超えています</span>
              </div>
              <%# メインカード %>
              <div class="rounded-xl bg-[#13daec]/10 border border-[#13daec]/20 p-4 mb-4 flex items-center justify-between">
                <div>
                  <p class="text-xs text-[#618689] dark:text-slate-400 mb-1">今月使えるお金</p>
                  <p class="text-3xl font-bold text-[#111718] dark:text-[#13daec]">¥150,830</p>
                  <p class="text-xs text-[#618689] dark:text-slate-500 mt-1">月収 ¥200,000 − 固定費 ¥49,170</p>
                </div>
                <div class="text-right">
                  <p class="text-xs text-[#618689] dark:text-slate-400 mb-1">固定費合計</p>
                  <p class="text-xl font-bold text-[#111718] dark:text-white">¥49,170</p>
                </div>
              </div>
              <%# プログレスバー %>
              <div class="w-full bg-gray-100 dark:bg-white/5 rounded-full h-2 mb-4">
                <div class="bg-[#13daec] h-2 rounded-full" style="width: 69%"></div>
              </div>
              <%# サブカード %>
              <div class="grid grid-cols-3 gap-3 mb-4">
                <div class="rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 p-3 text-center">
                  <p class="text-xs text-[#618689] dark:text-slate-400 mb-1">利用率</p>
                  <p class="text-lg font-bold text-[#13daec]">69%</p>
                </div>
                <div class="rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 p-3 text-center">
                  <p class="text-xs text-[#618689] dark:text-slate-400 mb-1">直近</p>
                  <p class="text-xs font-bold text-red-500">明日 電気代</p>
                </div>
                <div class="rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 p-3 text-center">
                  <p class="text-xs text-[#618689] dark:text-slate-400 mb-1">登録件数</p>
                  <p class="text-lg font-bold text-[#111718] dark:text-white">7件</p>
                </div>
              </div>
              <%# 引き落とし履歴 %>
              <div class="rounded-lg border border-gray-100 dark:border-white/10 overflow-hidden">
                <div class="flex justify-between items-center px-3 py-2 bg-gray-50 dark:bg-white/5 border-b border-gray-100 dark:border-white/10">
                  <span class="text-xs font-medium text-[#111718] dark:text-slate-300">直近の引き落とし履歴</span>
                  <span class="text-xs text-[#13daec]">すべて見る →</span>
                </div>
                <div class="divide-y divide-gray-100 dark:divide-white/5">
                  <div class="flex items-center justify-between px-3 py-2">
                    <span class="text-xs text-[#111718] dark:text-slate-300">Netflix</span>
                    <span class="text-xs bg-[#13daec]/10 text-[#13daec] px-2 py-0.5 rounded-full">サブスク</span>
                    <span class="text-xs text-[#618689] dark:text-slate-500">3月3日</span>
                    <span class="text-xs font-medium text-[#111718] dark:text-white">¥1,490</span>
                  </div>
                  <div class="flex items-center justify-between px-3 py-2">
                    <span class="text-xs text-[#111718] dark:text-slate-300">電気代</span>
                    <span class="text-xs bg-blue-100 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 px-2 py-0.5 rounded-full">公共料金</span>
                    <span class="text-xs text-[#618689] dark:text-slate-500">3月10日</span>
                    <span class="text-xs font-medium text-[#111718] dark:text-white">¥8,500</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -top-6 -right-6 z-0 w-32 h-32 bg-[#13daec]/20 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-6 -left-6 z-0 w-40 h-40 bg-teal-400/10 rounded-full blur-3xl"></div>
        </div>
      </section>

      <%# 統計バナー（保留中） %>
      <%#
      <section class="w-full bg-white dark:bg-[#1a2e30] rounded-2xl border border-gray-200 dark:border-white/10 shadow-sm p-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 divide-y md:divide-y-0 md:divide-x divide-gray-100 dark:divide-white/10">
        <div class="flex flex-col gap-1 px-4 text-center md:text-left">
          <div class="text-[#618689] dark:text-slate-400 text-sm font-medium uppercase tracking-wider">平均固定費件数</div>
          <div class="text-3xl font-black text-[#111718] dark:text-white">8件</div>
          <div class="text-[#13daec] text-sm font-bold flex items-center justify-center md:justify-start gap-1">↑ 見えていない固定費が多い</div>
        </div>
        <div class="flex flex-col gap-1 px-4 text-center md:text-left pt-4 md:pt-0">
          <div class="text-[#618689] dark:text-slate-400 text-sm font-medium uppercase tracking-wider">収入に占める固定費</div>
          <div class="text-3xl font-black text-[#111718] dark:text-white">約50%</div>
          <div class="text-green-600 dark:text-green-400 text-sm font-bold flex items-center justify-center md:justify-start gap-1">✓ 理想的な上限ライン</div>
        </div>
        <div class="flex flex-col gap-1 px-4 text-center md:text-left pt-4 md:pt-0">
          <div class="text-[#618689] dark:text-slate-400 text-sm font-medium uppercase tracking-wider">把握できていない固定費</div>
          <div class="text-3xl font-black text-[#111718] dark:text-white">2〜3件</div>
          <div class="text-[#13daec] text-sm font-bold flex items-center justify-center md:justify-start gap-1">↑ 平均的な見落とし数</div>
        </div>
        <div class="flex flex-col gap-1 px-4 text-center md:text-left pt-4 md:pt-0">
          <div class="text-[#618689] dark:text-slate-400 text-sm font-medium uppercase tracking-wider">登録の手間</div>
          <div class="text-3xl font-black text-[#111718] dark:text-white">1回だけ</div>
          <div class="text-green-600 dark:text-green-400 text-sm font-bold flex items-center justify-center md:justify-start gap-1">✓ 日々の入力不要</div>
        </div>
      </section>
      %>
      <%# 機能紹介セクション %>
      <section class="flex flex-col gap-12 py-12">
        <div class="text-center max-w-3xl mx-auto flex flex-col gap-4">
          <h2 class="text-3xl lg:text-5xl font-black tracking-tight text-[#111718] dark:text-white">
            固定費管理を<span class="text-[#13daec]">シンプルに</span>
          </h2>
          <p class="text-lg text-[#618689] dark:text-slate-400">
            難しい設定は不要。固定費を登録するだけで、あとは自動で管理してくれます。
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="group bg-white dark:bg-[#1a2e30] rounded-xl border border-gray-200 dark:border-white/10 p-6 shadow-sm hover:shadow-xl hover:shadow-[#13daec]/5 hover:border-[#13daec]/40 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 flex items-center justify-center mb-4 group-hover:bg-[#13daec] group-hover:text-[#111718] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#111718] dark:text-white mb-2">かんたん登録</h3>
            <p class="text-sm text-[#618689] dark:text-slate-400 leading-relaxed">カテゴリ・名前・金額・支払日を入力するだけ。一度登録すれば毎月自動で管理。</p>
          </div>

          <div class="group bg-white dark:bg-[#1a2e30] rounded-xl border border-gray-200 dark:border-white/10 p-6 shadow-sm hover:shadow-xl hover:shadow-[#13daec]/5 hover:border-[#13daec]/40 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mb-4 group-hover:bg-[#13daec] group-hover:text-[#111718] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#111718] dark:text-white mb-2">収入利用率を可視化</h3>
            <p class="text-sm text-[#618689] dark:text-slate-400 leading-relaxed">固定費が収入の何%を占めているか一目でわかる。カテゴリ別の内訳も確認できる。</p>
          </div>

          <div class="group bg-white dark:bg-[#1a2e30] rounded-xl border border-gray-200 dark:border-white/10 p-6 shadow-sm hover:shadow-xl hover:shadow-[#13daec]/5 hover:border-[#13daec]/40 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-pink-50 dark:bg-pink-500/10 text-pink-600 dark:text-pink-400 flex items-center justify-center mb-4 group-hover:bg-[#13daec] group-hover:text-[#111718] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#111718] dark:text-white mb-2">カレンダーで管理</h3>
            <p class="text-sm text-[#618689] dark:text-slate-400 leading-relaxed">支払日をカレンダーで一覧表示。いつ何が引き落とされるか先読みできる。</p>
          </div>

          <div class="group bg-white dark:bg-[#1a2e30] rounded-xl border border-gray-200 dark:border-white/10 p-6 shadow-sm hover:shadow-xl hover:shadow-[#13daec]/5 hover:border-[#13daec]/40 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-teal-50 dark:bg-teal-500/10 text-teal-600 dark:text-teal-400 flex items-center justify-center mb-4 group-hover:bg-[#13daec] group-hover:text-[#111718] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
