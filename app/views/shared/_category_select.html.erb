<%# app/views/

<div>
  <label class="block text-sm font-medium text-[#111718] dark:text-slate-300 mb-1">カテゴリ</label>

  <%# カスタムセレクト %>
  <div class="relative" data-custom-select id="category-select-wrapper">
    <%= form.hidden_field :category_id, data: { select_input: true }, id: "category_id_input" %>
    <button type="button"
            class="w-full h-11 px-4 rounded-lg bg-gray-50 dark:bg-[#1a2e30] border border-gray-200 dark:border-white/10 text-gray-400 dark:text-slate-400 text-left text-sm focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors flex items-center justify-between"
            data-select-trigger>
      <span class="flex items-center gap-2" data-select-label>
        <% if form.object.category_id.present? && (selected_cat = categories.find { |c| c.id == form.object.category_id }) %>
          <span class="w-3 h-3 rounded-full shrink-0" style="background-color: <%= selected_cat.color %>;"></span>
          <%= selected_cat.name %>
        <% else %>
          カテゴリを選択
        <% end %>
      </span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>

    <div class="hidden absolute z-50 w-full mt-1 rounded-lg bg-white dark:bg-[#1c2128] border border-gray-200 dark:border-[#30363d] shadow-lg overflow-hidden"
         data-select-dropdown>
      <div class="py-1 max-h-48 overflow-y-auto" id="category-dropdown-list">
        <div class="px-4 py-2.5 text-sm text-gray-400 dark:text-slate-500 cursor-default">
          カテゴリを選択
        </div>
        <% categories.each do |c| %>
          <div class="px-4 py-2.5 text-sm text-gray-900 dark:text-[#e6edf3] hover:bg-[#13daec]/10 hover:text-[#13daec] cursor-pointer transition-colors flex items-center gap-2"
               data-select-option="<%= c.id %>"
               data-select-text="<%= c.name %>"
               data-select-color="<%= c.color %>">
            <span class="w-3 h-3 rounded-full shrink-0" style="background-color: <%= c.color %>;"></span>
            <%= c.name %>
          </div>
        <% end %>
      </div>
      <%# 新規作成ボタン %>
      <div class="border-t border-gray-100 dark:border-[#30363d] px-3 py-2">
        <button type="button"
                id="open-category-modal"
                class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-bold text-[#13daec] hover:bg-[#13daec]/10 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          新しいカテゴリを作成
        </button>
      </div>
    </div>
  </div>
</div>

<%# カテゴリ作成モーダル %>
<div id="category-modal"
     class="fixed inset-0 z-50 items-center justify-center p-4"
     style="display:none">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="category-modal-backdrop"></div>
  <div class="relative z-10 w-full max-w-sm bg-white dark:bg-[#1c2128] rounded-2xl border border-gray-200 dark:border-[#30363d] shadow-2xl overflow-hidden">

    <div class="flex items-center justify-between px-5 pt-5 pb-3 border-b border-gray-100 dark:border-[#30363d]">
      <h3 class="text-base font-black text-[#111718] dark:text-[#e6edf3]">新しいカテゴリを作成</h3>
      <button type="button" id="close-category-modal"
              class="w-7 h-7 flex items-center justify-center rounded-lg hover:bg-gray-100 dark:hover:bg-[#30363d] text-[#618689] dark:text-[#7d8590] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="px-5 py-4 flex flex-col gap-4">

      <%# カテゴリ名 %>
      <div>
        <label class="block text-sm font-medium text-[#111718] dark:text-[#e6edf3] mb-1">カテゴリ名</label>
        <input type="text"
               id="new-category-name"
               placeholder="例：サブスク、保険"
               class="w-full h-10 px-3 rounded-lg bg-gray-50 dark:bg-[#161b22] border border-gray-200 dark:border-[#30363d] text-sm text-[#111718] dark:text-[#e6edf3] placeholder-gray-400 dark:placeholder-[#7d8590] focus:outline-none focus:ring-2 focus:ring-[#13daec]/50 focus:border-[#13daec] transition-colors">
      </div>

      <%# カラーパレット %>
      <div>
        <label class="block text-sm font-medium text-[#111718] dark:text-[#e6edf3] mb-2">カラー</label>
        <div class="flex flex-wrap gap-2" id="color-palette">
          <% [
            "#13daec", "#C7F284", "#f59e0b", "#ef4444", "#8b5cf6",
            "#ec4899", "#06b6d4", "#10b981", "#f97316", "#6366f1",
            "#84cc16", "#e879f9", "#fb7185", "#34d399", "#60a5fa"
          ].each do |color| %>
            <button type="button"
                    class="color-swatch w-7 h-7 rounded-full border-2 border-transparent hover:scale-110 transition-transform"
                    style="background-color: <%= color %>;"
                    data-color="<%= color %>">
            </button>
          <% end %>
        </div>
        <input type="hidden" id="new-category-color" value="#13daec">
        <%# プレビュー %>
        <div class="mt-3 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full" id="color-preview" style="background-color: #13daec;"></span>
          <span class="text-xs text-[#618689] dark:text-[#7d8590]" id="color-preview-text">#13daec</span>
        </div>
      </div>

      <%# エラー表示 %>
      <p id="category-modal-error" class="hidden text-xs text-red-500"></p>

      <%# ボタン %>
      <div class="flex gap-2 pt-1">
        <button type="button" id="cancel-category-modal"
                class="flex-1 h-10 rounded-lg border border-gray-200 dark:border-[#30363d] text-sm font-bold text-[#618689] dark:text-[#7d8590] hover:bg-gray-50 dark:hover:bg-[#161b22] transition-colors">
          キャンセル
        </button>
        <button type="button" id="save-category"
                class="flex-1 h-10 rounded-lg bg-[#13daec] text-sm font-bold text-[#111718] hover:bg-[#0fc8d8] transition-colors">
          作成する
        </button>
      </div>

    </div>
  </div>
</div>
